# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth
JWT_SECRET=your-secure-random-string
ADMIN_EMAIL=admin@example.com
# Generate with: npx tsx scripts/hash-password.ts 'your-password'
ADMIN_PASSWORD_HASH=your-bcrypt-hash

# Backblaze B2 image storage (S3-compatible)
# Create bucket at backblaze.com → B2 Cloud Storage → Create a Bucket
# Get keys at backblaze.com → App Keys → Add a New Application Key
R2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
R2_REGION=us-west-004
R2_ACCESS_KEY_ID=your-b2-key-id
R2_SECRET_ACCESS_KEY=your-b2-application-key
R2_BUCKET_NAME=campusnav
